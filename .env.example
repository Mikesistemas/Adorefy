# =========================================================
# ADOREFY - CONFIGURAÇÕES LOCAIS
# =========================================================
# Este arquivo contém apenas placeholders. Preencha com seus dados reais somente no servidor/local.
# Não publique suas credenciais reais no GitHub.

APP_NAME=Adorefy
APP_ENV=development
APP_DEBUG=true
APP_PUBLIC_URL=http://localhost:5000

# Segurança
SECRET_KEY=troque-esta-chave-secret-key
JWT_SECRET_KEY=troque-esta-chave-jwt

# Banco de dados
DATABASE_URL=sqlite:///database/adorefy.db

# YouTube API
YOUTUBE_API_KEY=

# SMTP / E-mail
SMTP_SERVER=
SMTP_PORT=587
SMTP_USE_TLS=true
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_TEST_RECIPIENT=

# WhatsApp / Integrações
WHATSAPP_MASTER_KEY=
WHATSAPP_SERVER_URL=
